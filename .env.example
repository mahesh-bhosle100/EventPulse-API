# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=False
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Security (prod)
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
USE_X_FORWARDED_PROTO=False

# MySQL
DB_NAME=event_ticketing
DB_USER=root
DB_PASSWORD=****
DB_HOST=localhost
# Docker: DB_HOST=db
DB_PORT=3306

# Redis
REDIS_URL=redis://localhost:6379/0
# Docker: REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Docker: set both to redis://redis:6379/0

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# API Throttling
THROTTLE_ANON=60/min
THROTTLE_USER=120/min
THROTTLE_LOGIN=10/min
THROTTLE_REGISTER=10/min
THROTTLE_PAYMENT=20/min
THROTTLE_CHECKIN=30/min

# Cache
CACHE_TTL=60

# Images
IMAGE_MAX_UPLOAD_MB=5
IMAGE_MAX_DIMENSION=1600
IMAGE_OPTIMIZE_QUALITY=80
